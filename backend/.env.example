# Email — Resend (primary for registration verification)
EMAIL_PROVIDER=resend
EMAIL_LEGACY_SMTP_ENABLED=false
RESEND_API_KEY=re_your_api_key_here
# Resend test sender (or your verified domain: CareBridge <noreply@yourdomain.com>)
RESEND_FROM=CareBridge Health <onboarding@resend.dev>

# Legacy SMTP (nodemailer) — kept in code, disabled by default
